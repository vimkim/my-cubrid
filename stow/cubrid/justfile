build-prepare-oos: build oos-prepare-server

build-update: cmake-build-install-all update-cubrid-conf

update-cubrid-conf:
    # sed -i 's/log_buffer_size=512M/log_buffer_size=4G/' $"($env.CUBRID)/conf/cubrid.conf"
    sed -i 's/data_buffer_size=512M/data_buffer_size=16G/' $"($env.CUBRID)/conf/cubrid.conf"

cubrid-conf-enable-string-compression: cubrid-conf-get-string-compression
    crudini --set $"($env.CUBRID)/conf/cubrid.conf" 'common' enable_string_compression yes
    echo "string compression enabled:"
    just cubrid-conf-get-string-compression

cubrid-conf-disable-string-compression: cubrid-conf-get-string-compression
    echo "string compression disabled:"
    crudini --set $"($env.CUBRID)/conf/cubrid.conf" 'common' enable_string_compression no
    just cubrid-conf-get-string-compression

cubrid-paramdump-testdb-string-compression:
    cub-auto paramdump testdb | rg enable_string_compression

cubrid-conf-get-string-compression:
    do -i { crudini --get $"($env.CUBRID)/conf/cubrid.conf" 'common' enable_string_compression }
    just cubrid-paramdump-testdb-string-compression

cubrid-conf-enable-use-system-malloc: cubrid-conf-get-use-system-malloc
    crudini --set $"($env.CUBRID)/conf/cubrid.conf" 'common' use_system_malloc yes
    just cubrid-conf-get-use-system-malloc

cubrid-conf-disable-use-system-malloc: cubrid-conf-get-use-system-malloc
    crudini --set $"($env.CUBRID)/conf/cubrid.conf" 'common' use_system_malloc no
    just cubrid-conf-get-use-system-malloc

cubrid-conf-get-use-system-malloc:
    do -i { crudini --get $"($env.CUBRID)/conf/cubrid.conf" 'common' use_system_malloc }

cubrid-conf-get-unfill-factor:
    do -i { crudini --get $"($env.CUBRID)/conf/cubrid.conf" 'common' unfill_factor }

cubrid-conf-set-unfill-factor:
    crudini --set $"($env.CUBRID)/conf/cubrid.conf" 'common' unfill_factor 0.0

cubrid-conf-get-port:
    crudini --get $"($env.CUBRID)/conf/cubrid.conf" 'common' cubrid_port_id

cubrid-conf-set-port: cubrid-conf-get-port
    crudini --set $"($env.CUBRID)/conf/cubrid.conf" 'common' cubrid_port_id 12345

cubrid-conf-get-data-buffer-size:
    crudini --get $"($env.CUBRID)/conf/cubrid.conf" 'common' data_buffer_size

cubrid-conf-data-buffer-set-20gb: cubrid-conf-get-data-buffer-size
    crudini --set $"($env.CUBRID)/conf/cubrid.conf" 'common' data_buffer_size 20G
    crudini --get $"($env.CUBRID)/conf/cubrid.conf" 'common' data_buffer_size

cubrid-conf-data-buffer-set-50gb: cubrid-conf-get-data-buffer-size
    crudini --set $"($env.CUBRID)/conf/cubrid.conf" 'common' data_buffer_size 50G
    crudini --get $"($env.CUBRID)/conf/cubrid.conf" 'common' data_buffer_size

cubrid-conf-data-buffer-set-512m: cubrid-conf-get-data-buffer-size
    crudini --set $"($env.CUBRID)/conf/cubrid.conf" 'common' data_buffer_size 512m
    crudini --get $"($env.CUBRID)/conf/cubrid.conf" 'common' data_buffer_size

