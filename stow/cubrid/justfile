set default-list
set minimum-version := "1.55.0"
set shell := ["sh", "-cu"]

import '.just/compat.just'

# Preset-aware configure, build, install, and ctest workflows.
mod core '.just/core.just'

# Local database lifecycle, server control, csql, and cubrid.conf workflows.
mod db '.just/db.just'

# CTP shell-test workflows.
mod ctp '.just/ctp.just'

# Interactive debugger and core workflows.
mod debug '.just/debug.just'

# Formatting and build-tree maintenance workflows.
mod maint '.just/maint.just'

# Profiling and tracing workflows.
mod profile '.just/profile.just'

# GitHub
mod github '.just/github.just'

# Shared Out-of-row Overflow Storage workflows.
mod oos '.just/oos.just'

# Optional ticket or worktree-specific workflows.
mod? local 'local.just'

# Create a sibling worktree and same-named branch from the current HEAD.
worktree name:
    cubrid-worktree-add.sh "{{ name }}" "{{ name }}" HEAD

# Create a sibling worktree with a separately named branch based on an existing ref.
worktree-as name new_branch base:
    cubrid-worktree-add.sh "{{ name }}" "{{ new_branch }}" "{{ base }}"

# Prepare this worktree's personal build environment.
prepare: core::prepare

# Configure the selected CMake preset.
configure: core::configure

# Set any valid CMake configure preset for this worktree.
preset mode: (core::set-preset mode)

# Select the commonly used GCC debug preset.
preset-debug-gcc: (core::set-preset "debug_gcc")

# Select the commonly used GCC release preset.
preset-release-gcc: (core::set-preset "release_gcc")

# Compile without installing.
compile: core::compile

# Install an already-compiled tree when its runtime is idle.
install: core::install

# Compile, install, and capture the complete build log.
build: core::build

configure-build: core::configure core::build

# Run configured ctest tests while holding the runtime lock.
ctest: core::ctest

# Run the currently configured test suite. This is intentionally ctest-only.
test: core::test

# Build, then run the currently configured test suite.
build-test: core::build-test

# Wait up to `timeout` seconds for an idle runtime, then build.
build-wait timeout='300': (core::build-wait timeout)

# Wait up to `timeout` seconds for an idle runtime, then install.
install-wait timeout='300': (core::install-wait timeout)

# Stop active CUBRID processes and build after explicit confirmation.
stop-and-build: core::stop-and-build
